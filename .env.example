NEW_BOOKS_DIR=/path/to/new_books
BOOKS_READY_DIR=/path/to/books_ready
FILENAME_TEMPLATE="{Authors} - {SeriesName} #{SeriesNumber} - {Title} [{Language}]"

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

DEBUG=1
DEBUG_DIR=debug_logs

MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=ebook_meta
MARIADB_USER=ebook
MARIADB_PASSWORD=ebook
DATABASE_URL=mysql+pymysql://ebook:ebook@mariadb:3306/ebook_meta
