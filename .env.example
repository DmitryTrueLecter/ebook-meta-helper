NEW_BOOKS_DIR=/path/to/new_books
BOOKS_READY_DIR=/path/to/books_ready
FILENAME_TEMPLATE="{Authors} - {SeriesName} #{SeriesNumber} - {Title} [{Language}]"

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

DEBUG=1
DEBUG_DIR=debug_logs

DB_ROOT_PASSWORD=root
DB_NAME=ebook_meta
DB_USER=ebook
DB_PASSWORD=ebook
DB_HOST=mariadb
DB_PORT=3306
DATABASE_URL="mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"